# OSINT CN 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==========================================
# 应用配置
# ==========================================
DEBUG=true
SECRET_KEY=your_secret_key_change_in_production
LOG_LEVEL=INFO

# ==========================================
# API 安全配置
# ==========================================

# 主 API Key（管理员权限，可选）
# 如果不设置，API 将不需要认证
# OSINT_API_KEY=your_master_api_key_here

# 额外的 API Keys（普通用户权限，可选）
# OSINT_API_KEY_1=
# OSINT_API_KEY_2=

# API 限流配置
# 每分钟最大请求数（匿名用户）
RATE_LIMIT_ANONYMOUS=30
# 每分钟最大请求数（认证用户）
RATE_LIMIT_AUTHENTICATED=100
# 每分钟最大请求数（管理员）
RATE_LIMIT_ADMIN=1000

# ==========================================
# PostgreSQL 配置
# ==========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db_name

# ==========================================
# MongoDB 配置
# ==========================================
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=osint_db
# 如需认证，取消以下注释
# MONGO_USER=
# MONGO_PASSWORD=

# ==========================================
# Redis 配置
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# 如需密码，取消以下注释
# REDIS_PASSWORD=

# ==========================================
# Elasticsearch 配置
# ==========================================
ES_HOST=elasticsearch
ES_PORT=9200
ES_SCHEME=http
# 如需认证，取消以下注释
# ES_USER=
# ES_PASSWORD=

# ==========================================
# Neo4j 配置
# ==========================================
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==========================================
# 平台采集配置（可选）
# ==========================================

# 微博 Cookie（登录后从浏览器获取）
# WEIBO_COOKIE=

# 知乎 Cookie（登录后从浏览器获取）
# ZHIHU_COOKIE=

# 小红书 Cookie（登录后从浏览器获取）
# XIAOHONGSHU_COOKIE=

# B站 Cookie（登录后从浏览器获取）
# BILIBILI_COOKIE=

# ==========================================
# 第三方 API Key（可选）
# ==========================================

# 百度 NLP API
# BAIDU_API_KEY=
# BAIDU_SECRET_KEY=

# 阿里云 NLP API
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=

# OpenAI API（用于高级分析）
# OPENAI_API_KEY=

# 代理配置（可选）
# HTTP_PROXY=
# HTTPS_PROXY=
